# Copy to .env.local for local development. Never commit real values.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Microsoft Graph — Entra app registration (client-credentials flow).
# Values come from the Azure portal: tenant ID, app (client) ID, and a client
# secret. Needs Sites.Read.All / Files.Read.All application permissions to
# read the master client list on SharePoint (see src/lib/graph.ts).
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
# Optional overrides — defaults in src/lib/graph.ts point at the current
# "Client List Final" workbook; set these when the master file moves.
# GRAPH_CLIENT_LIST_DRIVE_ID=
# GRAPH_CLIENT_LIST_ITEM_ID=

# Yeastar PBX (click-to-call)
YEASTAR_PBX_DOMAIN=
YEASTAR_PORT=
YEASTAR_CLIENT_ID=
YEASTAR_CLIENT_SECRET=
# YEASTAR_DIAL_PREFIX=

# WhatsApp follow-ups (Nextel)
NEXTEL_API_KEY=
NEXTEL_SEND_URL=
WHATSAPP_TEMPLATE_ID=
WHATSAPP_TEMPLATE_LANG=
WHATSAPP_WEBHOOK_SECRET=

# Cron / follow-up scheduler
CRON_SECRET=
# FOLLOWUP_MAX_ATTEMPTS=
# FOLLOWUP_RETRY_MINUTES=
# FOLLOWUP_WORK_START=
# FOLLOWUP_WORK_END=

# Seed script (scripts/seed-import.ts)
# SEED_EMAIL=
# SEED_PASSWORD=
